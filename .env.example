# SkillSphere AI Configuration
SECRET_KEY=your-secret-key-change-this-in-production
DATABASE_URL=sqlite:///./skillsphere.db
GEMINI_API_KEY=your-gemini-api-key-here

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════════════
# Firebase Configuration
# ═══════════════════════════════════════════════════════════════════════

# Firebase Client Config (Web/JS - Required for frontend Firebase Auth)
# Get these from: Firebase Console → Project Settings → General → Your apps
FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ───────────────────────────────────────────────────────────────────────
# Firebase Admin SDK (Server-side - Required for backend Firebase features)
# ───────────────────────────────────────────────────────────────────────
# 
# OPTION 1 (RECOMMENDED): Use service account file
# 1. Download from: Firebase Console → Settings → Service Accounts → Generate New Private Key
# 2. Save as firebase-service-account.json in project root
# 3. Set path below:
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
#
# OPTION 2: Use inline JSON string (for Render/production)
# Paste your entire service account JSON as a single minified line
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project",...}
#
# INSTRUCTIONS: See GET_FIREBASE_CREDENTIALS.md for detailed setup guide
# ═══════════════════════════════════════════════════════════════════════

